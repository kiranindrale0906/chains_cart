<form method="post" class="form-horizontal fields-group-sm form_radius_none" enctype="multipart/form-data"
      action="<?= get_form_action($controller, $action, $record) ?>">
  <div class="row">
    <?php if ($action == 'edit' || $action == 'update'): ?>
      <?php load_field('hidden', array('field' => 'id')) ?>
    <?php endif; ?>
    <?php load_field('dropdown', array('field' => 'product_name','option'=> $product_names)) ?>          
    <?php load_field('dropdown', array('field' => 'design_name','option'=> $design_names)) ?>        
    <?php load_field('text', array('field' => 'item_code')) ?>
    <?php load_field('dropdown', array('field' => 'melting','option'=>$meltings)) ?>
    <?php 
        if(HOST == "ARF"){
          load_field('text', array('field' => 'melting_lot_category_one')) ;
          load_field('text', array('field' => 'machine_size'));
        }
     ?>

  </div>
  <?php load_buttons('submit',array('name' => 'Save',
                                    'class' => 'btn-sm btn_green')) ?>
</form>
